# Copy to .env and adjust as needed.
# Most values are already set in docker-compose.yml; this file documents overrides.

# Kafka
KAFKA_BROKERS=kafka:9092

# MongoDB — Message Storage
STORAGE_MONGODB_URI=mongodb://storage-mongodb:27017
STORAGE_MONGODB_DATABASE=messaging

# MongoDB — Message Push
PUSH_MONGODB_URI=mongodb://push-mongodb:27017
PUSH_MONGODB_DATABASE=push

# Public API
PUBLIC_API_BIND_ADDR=0.0.0.0:8080
CHAT_SERVICE_URL=http://chat:8085
STORAGE_SERVICE_URL=http://message-storage:8087
USERS_SERVICE_URL=http://users:8088
JWT_SECRET=dev-jwt-secret-change-in-production
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Message Storage
STORAGE_BIND_ADDR=0.0.0.0:8087

# Message Delivery (WebSocket)
DELIVERY_BIND_ADDR=0.0.0.0:8081

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8081/ws
JWT_SECRET=dev-jwt-secret-change-in-production

# Chat
CHAT_MONGODB_URI=mongodb://chat-mongodb:27017
CHAT_MONGODB_DATABASE=chat
CHAT_BIND_ADDR=0.0.0.0:8085

# Users
USERS_MONGODB_URI=mongodb://users-mongodb:27017
USERS_MONGODB_DATABASE=users
USERS_BIND_ADDR=0.0.0.0:8088
JWT_SECRET=dev-jwt-secret-change-in-production

# Message Push
PUSH_CONNECTOR=dummy
