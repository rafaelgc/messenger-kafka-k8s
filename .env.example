# Copy to .env and adjust as needed.
# Most values are already set in docker-compose.yml; this file documents overrides.

# Kafka
KAFKA_BROKERS=kafka:9092

# MongoDB — Message Storage
STORAGE_MONGODB_URI=mongodb://storage-mongodb:27017
STORAGE_MONGODB_DATABASE=messaging

# MongoDB — Message Push
PUSH_MONGODB_URI=mongodb://push-mongodb:27017
PUSH_MONGODB_DATABASE=push

# Public API
PUBLIC_API_BIND_ADDR=0.0.0.0:8080

# Message Delivery (WebSocket)
DELIVERY_BIND_ADDR=0.0.0.0:8081

# Message Push
PUSH_CONNECTOR=dummy
