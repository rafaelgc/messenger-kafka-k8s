# Local development (Docker Compose: services on published host ports).
# For local Kubernetes (ingress), override when building, e.g.:
#   NEXT_PUBLIC_API_URL=http://api.localhost NEXT_PUBLIC_WS_URL=ws://ws.localhost/ws ./scripts/build-frontend.sh --dev --load-kind
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8081/ws
